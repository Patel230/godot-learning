[gd_scene load_steps=3 format=3]
[ext_resource type="Script" path="res://hud.gd" id="1"]

[sub_resource type="LabelSettings" id="1"]
font_size = 48
font_color = Color(0.95, 0.95, 0.95, 1.0)

[sub_resource type="LabelSettings" id="2"]
font_size = 24
font_color = Color(0.95, 0.95, 0.95, 1.0)

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1")

[node name="ScoreLabel" type="Label" parent="."]
offset_left = 0
offset_top = 20
offset_right = 1024
offset_bottom = 60
label_settings = SubResource("2")
text = "0"
horizontal_alignment = 2

[node name="MessageLabel" type="Label" parent="."]
offset_left = 0
offset_top = 250
offset_right = 1024
offset_bottom = 330
label_settings = SubResource("1")
text = "Dodge the Creeps"
horizontal_alignment = 1

[node name="MessageTimer" type="Timer" parent="."]
one_shot = true
wait_time = 2.0

[node name="Button" type="Button" parent="."]
offset_left = 462
offset_top = 350
offset_right = 562
offset_bottom = 400
text = "Start"

[connection signal="pressed" from="Button" to="." method="_on_button_pressed"]
[connection signal="timeout" from="MessageTimer" to="." method="_on_message_timer_timeout"]
